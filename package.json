{
  "name": "ja-plan-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:static && npm run build:vite",
    "build:static": "npm run build:tailwind && npm run generate:destinations && npm run generate:sitemap",
    "build:vite": "vite build",
    "build:tailwind": "tailwindcss -c tailwind.config.cjs -i src/styles/tailwind.css -o public/assets/css/tailwind.css --minify",
    "generate:destinations": "node scripts/generate-destination-pages.mjs",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "preview": "vite preview",
    "test": "node --test tests/*.test.mjs",
    "validate:cloudflare": "wrangler deploy --dry-run --config wrangler.jsonc"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "browserslist": "^4.28.6",
    "caniuse-lite": "^1.0.30001805",
    "linkedom": "0.18.13",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.0",
    "wrangler": "4.110.0"
  }
}
